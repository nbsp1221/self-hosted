# Public URL served by your reverse proxy.
SITE_URL=https://infisical.example.com

# Core secrets
# ENCRYPTION_KEY must be exactly 32 hex characters.
ENCRYPTION_KEY=<openssl rand -hex 16>
AUTH_SECRET=<openssl rand -base64 32>

# PostgreSQL
POSTGRES_USER=infisical
POSTGRES_PASSWORD=<openssl rand -hex 32>
POSTGRES_DB=infisical

# Redis
REDIS_PASSWORD=<openssl rand -hex 32>

# Mail / SMTP optional, but recommended for invites and account flows.
SMTP_HOST=
SMTP_PORT=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_IGNORE_TLS=false
SMTP_REQUIRE_TLS=true

# OAuth / SSO optional.
CLIENT_ID_GOOGLE_LOGIN=
CLIENT_SECRET_GOOGLE_LOGIN=
CLIENT_ID_GITHUB_LOGIN=
CLIENT_SECRET_GITHUB_LOGIN=
CLIENT_ID_GITLAB_LOGIN=
CLIENT_SECRET_GITLAB_LOGIN=

# Telemetry / monitoring optional.
OTEL_TELEMETRY_COLLECTION_ENABLED=false
OTEL_EXPORT_TYPE=prometheus
OTEL_EXPORT_OTLP_ENDPOINT=
OTEL_OTLP_PUSH_INTERVAL=
OTEL_COLLECTOR_BASIC_AUTH_USERNAME=
OTEL_COLLECTOR_BASIC_AUTH_PASSWORD=

# App connection integrations optional.
INF_APP_CONNECTION_AWS_ACCESS_KEY_ID=
INF_APP_CONNECTION_AWS_SECRET_ACCESS_KEY=
INF_APP_CONNECTION_GITHUB_OAUTH_CLIENT_ID=
INF_APP_CONNECTION_GITHUB_OAUTH_CLIENT_SECRET=
INF_APP_CONNECTION_GITHUB_APP_CLIENT_ID=
INF_APP_CONNECTION_GITHUB_APP_CLIENT_SECRET=
INF_APP_CONNECTION_GITHUB_APP_PRIVATE_KEY=
INF_APP_CONNECTION_GITHUB_APP_SLUG=
INF_APP_CONNECTION_GITHUB_APP_ID=
INF_APP_CONNECTION_GITLAB_OAUTH_CLIENT_ID=
INF_APP_CONNECTION_GITLAB_OAUTH_CLIENT_SECRET=

# Generate secure values:
# ENCRYPTION_KEY
# openssl rand -hex 16
#
# AUTH_SECRET
# openssl rand -base64 32
#
# POSTGRES_PASSWORD and REDIS_PASSWORD are embedded in connection URLs, so use
# hex or another URL-safe value unless you encode reserved characters yourself.
# openssl rand -hex 32
