# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_a_strong_random_string
POSTGRES_DB=n8n
POSTGRES_NON_ROOT_USER=n8n
POSTGRES_NON_ROOT_PASSWORD=replace_with_a_strong_random_string

# Redis Configuration
REDIS_PASSWORD=replace_with_a_strong_random_string

# n8n Configuration
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_HOST=localhost
WEBHOOK_URL=https://localhost:5678
N8N_PROXY_HOPS=1
N8N_ENCRYPTION_KEY=replace_with_a_strong_random_string
GENERIC_TIMEZONE=Asia/Seoul

# Generate strong secrets with:
# openssl rand -hex 32
